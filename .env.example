# --- Secret, kosongkan -> auto-generate saat deploy ---
JWT_SECRET=
API_KEY_SECRET=

# WAJIB diisi manual
INITIAL_PASSWORD=ganti-password-login-pertama

# Path data di DALAM container -- jangan diubah
DATA_DIR=/app/data

PORT=20128

REQUIRE_API_KEY=true

# Aktifkan container Headroom (proxy kompresi token, opsional).
# true = deploy container headroom di sebelah 9router, lalu tinggal enable manual
# di Dashboard 9Router -> Endpoint -> Token Saver -> Headroom (URL: http://headroom:8787)
ENABLE_HEADROOM=false

# --- Domain & SSL (dipakai deploy.sh untuk generate config nginx) ---
# Subdomain yang dipakai untuk 9Router, ganti sesuai domainmu
DOMAIN=9r.example.com

# Wajibkan client cert dari Cloudflare (mTLS / Authenticated Origin Pulls).
# Kalau true: WAJIB aktifkan dulu di Cloudflare dashboard -> SSL/TLS -> Origin Server ->
# Authenticated Origin Pulls -> Global -> On (dan SSL mode harus Full/Full strict),
# plus cloudflare_ca.pem harus ada di /etc/ssl/<CERT_BASE_DOMAIN>/
# Kalau belum di-enable di Cloudflare, biarkan false dulu (default) biar gak 400 Bad Request.
CF_AUTH_ORIGIN_PULLS=false
